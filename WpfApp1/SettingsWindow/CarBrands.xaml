<Window x:Class="WpfApp1.SettingsWindow.CarBrands"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1.SettingsWindow"
        xmlns:models="clr-namespace:WpfApp1.DataBase.Entity"
        mc:Ignorable="d"
        Title="CarBrands" Height="400" Width="450"
        Loaded="Window_Loaded" Closed="Window_Closed">
    <Window.Resources>
        <CollectionViewSource x:Key="BrandsViewSource"/>
    </Window.Resources>

    <Grid Background="#F0F8FF" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель ввода -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
               Text="Название марки:" 
               VerticalAlignment="Center" 
               Margin="0,0,10,0"/>

            <TextBox Grid.Column="1" 
             x:Name="BrandNameTextBox" 
             Height="25" 
             Padding="3"
             HorizontalAlignment="Stretch"/>
        </Grid>

        <!-- DataGrid с марками -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Source={StaticResource BrandsViewSource}}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0,0,0,1"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  x:Name="BrandsDataGrid">

            <!--SelectionChanged="BrandsDataGrid_SelectionChanged">-->
            <DataGrid.Columns>
                <DataGridTextColumn Header="Марка"
                                    Binding="{Binding BrandName}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <!--<Button Content="Добавить"
                    Width="80"
                    Height="30"
                    Margin="5"
                    Click="AddButton_Click"/>
            <Button Content="Изменить"
                    Width="80"
                    Height="30"
                    Margin="5"
                    Click="EditButton_Click"/>
            <Button Content="Удалить"
                    Width="80"
                    Height="30"
                    Margin="5"
                    Click="DeleteButton_Click"/>-->
        </StackPanel>
    </Grid>
</Window>