<Window x:Class="TechSto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechSto"
        xmlns:controls="clr-namespace:TechSto.Controls"
        xmlns:properties="clr-namespace:TechSto.Properties"
        mc:Ignorable="d"
        Title="Приложение"        
        MaxWidth="1920" MaxHeight="1080"
        MinWidth="1366" MinHeight="768"
        
        Loaded="Window_Loaded">

    <Grid Background="#F0F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель вкладок слева -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Вкладка "Установки" -->
            <Border x:Name="SettingsTab" 
                    Grid.Row="0" 
                    Style="{StaticResource SelectedTabStyleSet}"                                      
                    MouseDown="Tab_MouseDown"
                    Tag="Settings">              
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="📋" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="SettingsTabText" Text="{x:Static properties:Resources.Settings}" Style="{StaticResource TabTextStyle}"/>                    
                </StackPanel>
            </Border>

            <!-- Разделительная линия после первой вкладки -->
            <Border Grid.Row="0" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,82,10,0"/>

            <!-- Вкладка "Измерения" -->
            <Border x:Name="MeasurementsTab" 
                    Grid.Row="1" 
                    Style="{StaticResource SelectedTabStyle}"                     
                    MouseDown="Tab_MouseDown"
                    Tag="Measurements">                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="📊" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="MeasurementsTabText" Text="{x:Static properties:Resources.Measurements}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после второй вкладки -->
            <Border Grid.Row="1" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,62,10,0"/>

            <!-- Вкладка "Отчеты" --> 
            <Border x:Name="ReportsTab" 
                    Grid.Row="2" 
                    Style="{StaticResource SelectedTabStyle}"  
                    MouseDown="Tab_MouseDown"
                    Tag="Reports">               
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="📈" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="ReportsTabText" Text="{x:Static properties:Resources.Reports}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после третьей вкладки -->
            <Border Grid.Row="2" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,62,10,0"/>

            <!-- Вкладка "Справка" -->
            <Border x:Name="HelpTab" 
                    Grid.Row="3" 
                   Style="{StaticResource SelectedTabStyle}"  
                    MouseDown="Tab_MouseDown"
                    Tag="Help">            
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="❓" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="HelpTabText" Text="{x:Static properties:Resources.Help}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после четвертой вкладки -->
            <Border Grid.Row="3" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,62,10,0"/>

            <!-- Вкладка "О программе" -->
            <Border x:Name="AboutTab" 
                    Grid.Row="4"  
                    Style="{StaticResource SelectedTabStyle}"  
                    MouseDown="Tab_MouseDown"
                    Tag="About">               
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="ℹ️" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="AboutTabText" Text="{x:Static properties:Resources.About}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после пятой вкладки -->
            <Border Grid.Row="4" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,62,10,0"/>
        </Grid>

        <!-- Основная область контента -->
        <Grid x:Name="ContentArea" Grid.Column="1" Background="#F0F8FF">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>   
            </Grid.RowDefinitions>

            <!-- Контент для Установки -->
            <Grid x:Name="SettingsContent" Visibility="Visible" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="65"/>
                </Grid.RowDefinitions>

                <!-- Верхняя часть разделена на две колонки -->
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="800"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая панель -->
                    <Border Grid.Column="0" Background="White" CornerRadius="5" Margin="0,0,5,0">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                        </Border.Effect>

                        <!-- Основной Grid, занимающий всю высоту Border -->
                        <Grid Margin="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Поле поиска -->
                                <RowDefinition Height="*"/>
                                <!-- DataGrid -->
                                <RowDefinition Height="Auto"/>
                                <!-- Кнопки -->
                            </Grid.RowDefinitions>

                            <!-- Поле поиска / фильтра (растянуто на всю ширину колонки) -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SearchLabel"  Grid.Column="0" Text="{x:Static properties:Resources.SearchLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1"
                                         x:Name="InputTextBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="25" Padding="3"/>
                            </Grid>

                            <!-- DataGrid с нужными колонками -->
                            <DataGrid Grid.Row="1"
                      x:Name="CarsDataGrid"
                      ItemsSource="{Binding CarsView}"
                      SelectedItem="{Binding SelectedCar, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      AlternatingRowBackground="#F5F5F5"
                      RowHeaderWidth="0"
                      Margin="0,0,0,10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn x:Name="ColOwnerHeader" Header="Владелец" Binding="{Binding Owner}" Width="*"/>
                                    <DataGridTextColumn x:Name="ColStateNumberHeader" Header="Гос номер" Binding="{Binding StateNumber}" Width="120"/>
                                    <DataGridTextColumn x:Name="ColVinHeader" Header="Vin номер" Binding="{Binding Vin}" Width="150"/>
                                    <DataGridTextColumn x:Name="ColBrandHeader" Header="Марка" Binding="{Binding BrandName}" Width="100"/>
                                    <DataGridTextColumn x:Name="ColModelHeader" Header="Модель" Binding="{Binding Model}" Width="100"/>
                                    <DataGridTextColumn x:Name="ColLastTestHeader" Header="Дата последнего испытания" Binding="{Binding LastTestDate, StringFormat='dd.MM.yyyy'}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Панель кнопок -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Button x:Name="AddBtn" Width="100" Height="30" Margin="5" Click="AddButton_Click"/>
                                <Button x:Name="EditBtn" Width="100" Height="30" Margin="5" Click="EditButton_Click"/>
                                <Button x:Name="DeleteBtn" Width="100" Height="30" Margin="5" Click="DeleteButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Правая панель с кнопкой и EntityManager -->
                    <Border Grid.Column="1" Background="White" CornerRadius="5">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                        </Border.Effect>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedCar}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock x:Name="PreviewSectionOwnerLabel" Text="Владелец" FontWeight="SemiBold" Margin="0,2,0,4"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="PreviewOwnerNameLabel" Text="Имя:" Foreground="#555"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PreviewOwner}"/>
                                    <TextBlock x:Name="PreviewOwnerStsLabel" Grid.Row="1" Text="СТС:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewOwnerSts}" Margin="0,4,0,0"/>
                                </Grid>

                                <TextBlock x:Name="PreviewSectionCarLabel" Text="Автомобиль" FontWeight="SemiBold" Margin="0,2,0,4"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="PreviewGosLabel" Text="Госномер:" Foreground="#555"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PreviewGos}"/>
                                    <TextBlock x:Name="PreviewVinLabel" Grid.Row="1" Text="VIN:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewVin}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="PreviewBrandLabel" Grid.Row="2" Text="Марка:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewBrand}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="PreviewModelLabel" Grid.Row="3" Text="Модель:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PreviewModel}" Margin="0,4,0,0"/>
                                </Grid>

                                <TextBlock x:Name="PreviewSectionSpecsLabel" Text="Характеристики" FontWeight="SemiBold" Margin="0,2,0,4"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="PreviewCategoryLabel" Text="Категория:" Foreground="#555"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PreviewCategory}"/>
                                    <TextBlock x:Name="PreviewMaxMassLabel" Grid.Row="1" Text="Макс. масса:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewMaxMass}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="PreviewCurbMassLabel" Grid.Row="2" Text="Снаряж. масса:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewCurbMass}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="PreviewBrakeDiffLabel" Grid.Row="3" Text="Разн. торм.:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PreviewBrakeDiff}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="PreviewParkingBrakeLabel" Grid.Row="4" Text="Стояночный:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewParkingBrake}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="PreviewReserveBrakeLabel" Grid.Row="5" Text="Резервный:" Foreground="#555" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding PreviewReserveBrake}" Margin="0,4,0,0"/>
                                </Grid>

                                <TextBlock x:Name="PreviewSectionAxlesLabel" Text="Оси" FontWeight="SemiBold" Margin="0,2,0,4"/>
                                <ItemsControl ItemsSource="{Binding PreviewAxles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock x:Name="PreviewLastCheckCaptionLabel"
                                               Text="Последняя проверка:"
                                               Foreground="#555"/>
                                    <TextBlock Text="{Binding PreviewLastTest}" Foreground="#555" Margin="4,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Разделительная линия -->
                <Border Grid.Row="1" 
            Style="{StaticResource DividerStyle}"
            Margin="10,0,10,10"
            VerticalAlignment="Top"/>

                <!-- Нижняя панель с выбором языка -->
                <Border Grid.Row="1" Background="White" CornerRadius="5" Margin="0,5,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,10,0,0">
                        <ComboBox x:Name="LanguageComboBox" 
                      Style="{StaticResource ComboBoxStyle}"
                      SelectionChanged="LanguageComboBox_SelectionChanged">
                            <ComboBoxItem Tag="ru-RU" IsSelected="True">🇷🇺 Русский</ComboBoxItem>
                            <ComboBoxItem Tag="en-US">🇬🇧 English</ComboBoxItem>
                            <ComboBoxItem Tag="kk-KZ">🇰🇿 Қазақша</ComboBoxItem>
                            <ComboBoxItem Tag="uz-Latn-UZ">🇺🇿 O'zbekcha</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Контент для Измерения -->
            <Grid x:Name="MeasurementsContent" Visibility="Collapsed" Margin="10">
                <Border Background="White" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Проведение и анализ измерений" 
                                   FontSize="18" 
                                   Foreground="#666666"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Контент для Отчеты -->
            <Grid x:Name="ReportsContent" Visibility="Collapsed" Margin="10">
                <Border Background="White" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Формирование и просмотр отчетов" 
                                   FontSize="18" 
                                   Foreground="#666666"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Контент для Справка -->
            <Grid x:Name="HelpContent" Visibility="Collapsed" Margin="10">
                <Border Background="White" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                         <TextBlock Text="Документация и помощь по использованию" 
                                   FontSize="18" 
                                   Foreground="#666666"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Контент для О программе -->
            <Grid x:Name="AboutContent" Visibility="Collapsed" Margin="10">
                <Border Background="White" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                         <TextBlock Text="Версия 1.0.0 ©2026" 
                                   FontSize="18" 
                                   Foreground="#666666"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>