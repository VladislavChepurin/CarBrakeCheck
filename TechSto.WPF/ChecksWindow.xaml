<Window x:Class="TechSto.WPF.ChecksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechSto.WPF"
        xmlns:helpers="clr-namespace:TechSto.WPF.Helpers"
        xmlns:converters="clr-namespace:TechSto.WPF.Converters"
        mc:Ignorable="d"
        Title="{Binding LocalizationProvider[ChecksWindowTitle], Mode=OneWay}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="#F0F8FF"
        MinWidth="400"
        MaxWidth="600"
        MaxHeight="600">

    <Window.Resources>
        <converters:BoolToCheckResultConverter x:Key="BoolToCheckResultConverter"/>
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />              
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация о владельце и автомобиле -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock>
                    <Run Text="{Binding LocalizationProvider[PreviewSectionOwner], Mode=OneWay}"/>
                    <Run Text=": "/>
                    <Run Text="{Binding OwnerInfo}"/>
                </TextBlock>
                <TextBlock Margin="0,5,0,0">
                    <Run Text="{Binding LocalizationProvider[CarInfo], Mode=OneWay}"/>
                    <Run Text=": "/>
                    <Run Text="{Binding CarInfo}"/>
                    <Run Text=" ("/>
                    <Run Text="{Binding GosNumber}"/>
                    <Run Text=")"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- DataGrid с проверками -->
        <Border Grid.Row="1" Grid.RowSpan="2" Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                <DataGrid ItemsSource="{Binding Checks}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          Background="Transparent"
                          BorderThickness="0"
                          AlternatingRowBackground="#F5F5F5"
                          Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" 
                                            Binding="{Binding Number}" 
                                            Width="50"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>

                        <DataGridTextColumn Header="{Binding Data.LocalizationProvider[DateColumnHeader], Mode=OneWay, Source={StaticResource Proxy}}" 
                                            Binding="{Binding Date, StringFormat='dd.MM.yyyy HH:mm:ss'}" Width="150"
                                            CellStyle="{StaticResource DataGridCellStyle}"/>

                        <DataGridTemplateColumn Header="{Binding Data.LocalizationProvider[ResultColumnHeader], Mode=OneWay, Source={StaticResource Proxy}}" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsPassed, Converter={StaticResource BoolToCheckResultConverter}}" 
                       VerticalAlignment="Center" Margin="5,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPassed}" Value="True">
                                                        <Setter Property="Foreground" Value="Green"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsPassed}" Value="False">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Border>

        <!-- Кнопка закрытия -->
        <Button Grid.Row="3" 
                Content="{Binding LocalizationProvider[CloseButton], Mode=OneWay}"
                Command="{Binding CloseCommand}"
                Width="100"
                Height="30"
                Margin="0,15,0,0"
                HorizontalAlignment="Center"/>
    </Grid>
</Window>