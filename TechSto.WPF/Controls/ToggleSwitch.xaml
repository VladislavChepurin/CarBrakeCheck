<UserControl x:Class="TechSto.WPF.Controls.ToggleSwitch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TechSto.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="160">
    <Grid>
        <StackPanel Margin="0,0,0,10">
            <TextBlock Text="{Binding LocalizationProvider[MeasurementMode], Mode=OneWay}" Style="{StaticResource RightColumnHeaderTextStyle}"/>

            <!-- Переключатель -->
            <Grid Width="160"
          Height="40"
          Margin="0,5"
          x:Name="ModeSwitch"
          MouseLeftButtonDown="ModeSwitch_MouseDown"
          MouseMove="ModeSwitch_MouseMove"
          MouseLeftButtonUp="ModeSwitch_MouseUp">

                <!-- Фон -->
                <Border Background="#E6F3FF" CornerRadius="5"/>

                <!-- Ползунок -->
                <Canvas Margin="2">
                    <Border x:Name="Slider"
                 Width="80"
                 Height="36"
                 CornerRadius="5"
                 Background="{StaticResource PrimaryBrush}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="SliderTransform"/>
                        </Border.RenderTransform>
                    </Border>
                </Canvas>

                <!-- Текст (поверх ползунка) -->
                <Grid IsHitTestVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="{Binding LocalizationProvider[AutoBth]}"
                FontWeight="SemiBold"/>

                    <TextBlock Grid.Column="1"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Text="{Binding LocalizationProvider[ManualBth]}"
                 FontWeight="SemiBold"/>
                </Grid>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
