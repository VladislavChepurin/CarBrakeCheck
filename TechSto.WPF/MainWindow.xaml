<Window x:Class="TechSto.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechSto.WPF"
        xmlns:converters="clr-namespace:TechSto.WPF.Converters"
        xmlns:properties="clr-namespace:TechSto.WPF.Properties"
        xmlns:helpers="clr-namespace:TechSto.WPF.Helpers"
        mc:Ignorable="d"
        Title="{Binding LocalizationProvider[NameProgram]}"    
        Width="1366" Height="768"
        ResizeMode="NoResize">

    <Window.Resources>
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <converters:EqualityToBooleanConverter x:Key="EqualityToBooleanConverter"/>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZero"/>
        <converters:ModeToColorConverter x:Key="ModeToColorConverter"/>
    </Window.Resources>


    <Grid Background="#F0F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="46.5"/>
            <ColumnDefinition Width="153.5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель вкладок слева -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Вкладка "Установки" -->
            <Border x:Name="SettingsTab" 
                    Grid.Row="0" 
                    Style="{StaticResource SelectedTabStyleSet}"                                      
                    MouseDown="Tab_MouseDown"
                    Tag="Settings">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="📋" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="SettingsTabText" Text="{Binding LocalizationProvider[Settings]}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после первой вкладки -->
            <Border Grid.Row="0" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,82,10,0"/>

            <!-- Вкладка "Измерения" -->
            <Border x:Name="MeasurementsTab" 
                    Grid.Row="1" 
                    Style="{StaticResource SelectedTabStyle}"                     
                    MouseDown="Tab_MouseDown"
                    Tag="Measurements">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="📊" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="MeasurementsTabText" Text="{Binding LocalizationProvider[Measurements]}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после второй вкладки -->
            <Border Grid.Row="1" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,62,10,0"/>

            <!-- Вкладка "Отчеты" -->
            <Border x:Name="ReportsTab" 
                    Grid.Row="2" 
                    Style="{StaticResource SelectedTabStyle}"  
                    MouseDown="Tab_MouseDown"
                    Tag="Reports">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="📈" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="ReportsTabText" Text="{Binding LocalizationProvider[Reports]}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после третьей вкладки -->
            <Border Grid.Row="2" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,62,10,0"/>

            <!-- Вкладка "Справка" -->
            <Border x:Name="HelpTab" 
                    Grid.Row="3" 
                   Style="{StaticResource SelectedTabStyle}"  
                    MouseDown="Tab_MouseDown"
                    Tag="Help">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="❓" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="HelpTabText" Text="{Binding LocalizationProvider[Help]}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после четвертой вкладки -->
            <Border Grid.Row="3" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,62,10,0"/>

            <!-- Вкладка "О программе" -->
            <Border x:Name="AboutTab" 
                    Grid.Row="4"  
                    Style="{StaticResource SelectedTabStyle}"  
                    MouseDown="Tab_MouseDown"
                    Tag="About">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="15,0,0,0">
                    <TextBlock Text="ℹ️" Style="{StaticResource TabIconStyle}"/>
                    <TextBlock x:Name="AboutTabText" Text="{Binding LocalizationProvider[About]}" Style="{StaticResource TabTextStyle}"/>
                </StackPanel>
            </Border>

            <!-- Разделительная линия после пятой вкладки -->
            <Border Grid.Row="4" 
                    Style="{StaticResource DividerStyle}"
                    Margin="10,62,10,0"/>

            <Border Grid.Row="5" VerticalAlignment="Bottom" Margin="10,0,10,20" Height="Auto">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                        <Setter Property="Fill" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock VerticalAlignment="Center" Foreground="#333333">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding LocalizationProvider[EquipmentIsNotConnected]}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                        <Setter Property="Text" Value="{Binding LocalizationProvider[EquipmentIsConnected]}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Основная область контента -->
        <Grid x:Name="ContentArea" Grid.Column="2" Background="#F0F8FF">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Контент для Установки -->
            <Grid x:Name="SettingsContent" Visibility="Visible" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="65"/>
                </Grid.RowDefinitions>

                <!-- Верхняя часть разделена на две колонки -->
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="800"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая панель -->
                    <Border Grid.Column="0" Background="White" CornerRadius="5" Margin="0,0,5,0">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                        </Border.Effect>

                        <!-- Основной Grid, занимающий всю высоту Border -->
                        <Grid Margin="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Поле поиска -->
                                <RowDefinition Height="*"/>
                                <!-- DataGrid -->
                                <RowDefinition Height="Auto"/>
                                <!-- Кнопки -->
                            </Grid.RowDefinitions>

                            <!-- Поле поиска / фильтра (растянуто на всю ширину колонки) -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SearchLabel"  Grid.Column="0" Text="{Binding LocalizationProvider[SearchLabel]}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" x:Name="InputTextBox" Height="25" Padding="3"/>
                            </Grid>

                            <!-- DataGrid с нужными колонками -->
                            <DataGrid x:Name="MainTableWithClientData" Grid.Row="1"    
                                 ItemsSource="{Binding ClientRecords}"
                                 SelectedItem="{Binding SelectedClientRecord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"     
                                 AutoGenerateColumns="False"
                                 CanUserAddRows="False"
                                 IsReadOnly="True"
                                 GridLinesVisibility="None"
                                 AlternatingRowBackground="#F5F5F5"
                                 RowHeaderWidth="0"
                                 Margin="0,0,0,10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{Binding Data.LocalizationProvider[OnwerHeader], Source={StaticResource Proxy}}" Binding="{Binding Owner}" Width="*"/>
                                    <DataGridTextColumn Header="{Binding Data.LocalizationProvider[CarNumberHeader], Source={StaticResource Proxy}}" Binding="{Binding StateNumber}" Width="120"/>
                                    <DataGridTextColumn Header="{Binding Data.LocalizationProvider[VinNumberHeader], Source={StaticResource Proxy}}" Binding="{Binding Vin}" Width="150"/>
                                    <DataGridTextColumn Header="{Binding Data.LocalizationProvider[CarBrandHeader], Source={StaticResource Proxy}}"  Binding="{Binding BrandName}" Width="100"/>
                                    <DataGridTextColumn Header="{Binding Data.LocalizationProvider[CarModelHeader], Source={StaticResource Proxy}}"  Binding="{Binding Model}" Width="100"/>
                                    <DataGridTextColumn Header="{Binding Data.LocalizationProvider[DateLastTestHeader], Source={StaticResource Proxy}}" Binding="{Binding LastTestDate, StringFormat='dd.MM.yyyy'}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Панель кнопок -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Button Content="{Binding LocalizationProvider[AddBth]}" Command="{Binding OpenAddClientCommand}" Width="100" Height="30" Margin="5"/>
                                <Button Content="{Binding LocalizationProvider[UpdateBth]}" Width="100" Height="30" Margin="5"/>
                                <Button Content="{Binding LocalizationProvider[DeleteBth]}" Width="100" Height="30" Margin="5"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Правая панель -->
                    <Border Grid.Column="1" CornerRadius="5">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <!-- Заполнитель, если нужно прижать кнопку к низу -->
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">                              
                                <StackPanel>
                                    <TextBlock Text="{Binding LocalizationProvider[SelectedAuto]}" Style="{StaticResource RightColumnHeaderTextStyle}"/>
                                    <TextBlock Text="{Binding SelectedCarDisplay}" Style="{StaticResource RightColumnTextStyle}"/>
                                    <TextBlock Text="{Binding CarCategory, StringFormat='Категория: {0}'}" Style="{StaticResource RightColumnTextStyle}"/>
                                    <TextBlock Text="{Binding AxlesCount, StringFormat='Кол-во осей: {0}'}" Style="{StaticResource RightColumnTextStyle}"/>
                                    <CheckBox Content="{Binding LocalizationProvider[RegardingManufacturerDifference]}" IsChecked="{Binding IsRelativeDifference}" Style="{StaticResource RightColumnCheckBoxStyle}"/>
                                </StackPanel>
                            </Border>

                            <!-- Блок 2: Режим измерений -->
                            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">                             
                                <StackPanel>
                                    <TextBlock Text="{Binding LocalizationProvider[MeasurementMode]}" Style="{StaticResource RightColumnHeaderTextStyle}"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5">
                                        <Button Content="{Binding LocalizationProvider[ManualBth]}" Command="{Binding ManualModeCommand}" Width="80" Margin="2" 
                            Background="{Binding SelectedMeasurementMode, Converter={StaticResource ModeToColorConverter}, ConverterParameter=0}"/>
                                        <Button Content="{Binding LocalizationProvider[AutoBth]}" Command="{Binding AutoModeCommand}" Width="80" Margin="2" 
                            Background="{Binding SelectedMeasurementMode, Converter={StaticResource ModeToColorConverter}, ConverterParameter=1}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Блок 3: Вид измерений -->
                            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">                               
                                <StackPanel>
                                    <TextBlock Text="{Binding LocalizationProvider[TypeOfMeasurements]}" Style="{StaticResource RightColumnHeaderTextStyle}"/>
                                    <ComboBox ItemsSource="{Binding AxleItems}" SelectedItem="{Binding SelectedAxle}" 
                          Margin="0,5" IsEnabled="{Binding AxlesCount, Converter={StaticResource GreaterThanZero}}"/>
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="5,0,0,0">
                                        <RadioButton GroupName="MeasurementType" Content="{Binding LocalizationProvider[EntryDryingRadioBth]}"  
                                 IsChecked="{Binding SelectedMeasurementType, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=0}" Style="{StaticResource RightColumnRadioButtonStyle}"/>
                                        <RadioButton GroupName="MeasurementType" Content="{Binding LocalizationProvider[FullLoadRadioBth]}" 
                                 IsChecked="{Binding SelectedMeasurementType, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=1}" Style="{StaticResource RightColumnRadioButtonStyle}"/>
                                        <RadioButton GroupName="MeasurementType" Content="{Binding LocalizationProvider[ParkingVehicleRadioBth]}"   
                                 IsChecked="{Binding SelectedMeasurementType, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=2}" Style="{StaticResource RightColumnRadioButtonStyle}"/>
                                        <RadioButton GroupName="MeasurementType" Content="{Binding LocalizationProvider[EntryRadioBth]}"           
                                 IsChecked="{Binding SelectedMeasurementType, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=3}" Style="{StaticResource RightColumnRadioButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Блок 4: Кнопка Старт -->
                            <Button Grid.Row="3" Content="{Binding LocalizationProvider[StartBth]}" Command="{Binding StartCommand}" 
                Height="40" Background="{StaticResource PrimaryLightBrush}" Foreground="{StaticResource CommonTextBrush}" FontSize="16" Margin="0,0,0,10"/>
                        </Grid>
                    </Border>
                </Grid>
                <!-- Разделительная линия -->
                <Border Grid.Row="1" Style="{StaticResource DividerStyle}" Margin="10,0,10,10" VerticalAlignment="Top"/>

                <!-- Нижняя панель с выбором языка -->
                <Border Grid.Row="1" Background="White" CornerRadius="5" Margin="0,5,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,10,0,0">
                        <ComboBox x:Name="LanguageComboBox" 
                      Style="{StaticResource ComboBoxStyle}"
                      SelectionChanged="LanguageComboBox_SelectionChanged">
                            <ComboBoxItem Tag="ru-RU">🇷🇺 Русский</ComboBoxItem>
                            <ComboBoxItem Tag="en-US">🇬🇧 English</ComboBoxItem>
                            <ComboBoxItem Tag="kk-KZ">🇰🇿 Қазақша</ComboBoxItem>
                            <ComboBoxItem Tag="uz-Latn-UZ">🇺🇿 O'zbekcha</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Контент для Измерения -->
            <Grid x:Name="MeasurementsContent" Visibility="Collapsed" Margin="10">
                <Border Background="White" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Проведение и анализ измерений" 
                                   FontSize="18" 
                                   Foreground="#666666"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Контент для Отчеты -->
            <Grid x:Name="ReportsContent" Visibility="Collapsed" Margin="10">
                <Border Background="White" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Формирование и просмотр отчетов" 
                                   FontSize="18" 
                                   Foreground="#666666"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Контент для Справка -->
            <Grid x:Name="HelpContent" Visibility="Collapsed" Margin="10">
                <Border Background="White" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Документация и помощь по использованию" 
                                   FontSize="18" 
                                   Foreground="#666666"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Контент для О программе -->
            <Grid x:Name="AboutContent" Visibility="Collapsed" Margin="10">
                <Border Background="White" CornerRadius="5">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Версия 1.0.0\n© 2024 Все права защищены" 
                                   FontSize="18" 
                                   Foreground="#666666"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>