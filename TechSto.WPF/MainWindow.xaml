<Window x:Class="TechSto.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TechSto.WPF.ViewModels"
        mc:Ignorable="d"
        Title="{Binding LocalizationProvider[NameProgram]}"
        Width="1366"
        Height="768"
        ResizeMode="NoResize">

    <Grid Background="#F0F8FF">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- ========================= -->
        <!-- ЛЕВАЯ ПАНЕЛЬ НАВИГАЦИИ -->
        <!-- ========================= -->

        <Grid Grid.Column="0">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>


            <!-- Settings -->

            <Button Grid.Row="0"
                    Command="{Binding ShowSettingsCommand}"
                    Margin="10"
                    Height="60">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="📋"
                               FontSize="18"
                               Margin="5"/>

                    <TextBlock Text="{Binding LocalizationProvider[Settings]}"
                               VerticalAlignment="Center"
                               Margin="5"/>

                </StackPanel>

            </Button>


            <!-- Measurements -->

            <Button Grid.Row="1"
                    Command="{Binding ShowMeasurementsCommand}"
                    Margin="10"
                    Height="60">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="📊"
                               FontSize="18"
                               Margin="5"/>

                    <TextBlock Text="{Binding LocalizationProvider[Measurements]}"
                               VerticalAlignment="Center"
                               Margin="5"/>

                </StackPanel>

            </Button>


            <!-- Reports -->

            <Button Grid.Row="2"
                    Command="{Binding ShowReportsCommand}"
                    Margin="10"
                    Height="60">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="📈"
                               FontSize="18"
                               Margin="5"/>

                    <TextBlock Text="{Binding LocalizationProvider[Reports]}"
                               VerticalAlignment="Center"
                               Margin="5"/>

                </StackPanel>

            </Button>


            <!-- Help -->

            <Button Grid.Row="3"
                    Command="{Binding ShowHelpCommand}"
                    Margin="10"
                    Height="60">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="❓"
                               FontSize="18"
                               Margin="5"/>

                    <TextBlock Text="{Binding LocalizationProvider[Help]}"
                               VerticalAlignment="Center"
                               Margin="5"/>

                </StackPanel>

            </Button>


            <!-- About -->

            <Button Grid.Row="4"
                    Command="{Binding ShowAboutCommand}"
                    Margin="10"
                    Height="60">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="ℹ️"
                               FontSize="18"
                               Margin="5"/>

                    <TextBlock Text="{Binding LocalizationProvider[About]}"
                               VerticalAlignment="Center"
                               Margin="5"/>

                </StackPanel>

            </Button>


            <!-- ========================= -->
            <!-- СТАТУС УСТРОЙСТВА -->
            <!-- ========================= -->

            <Border Grid.Row="5"
                    VerticalAlignment="Bottom"
                    Margin="10,0,10,20">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Ellipse Width="12"
                             Height="12"
                             Margin="0,0,5,0"
                             VerticalAlignment="Center">

                        <Ellipse.Style>

                            <Style TargetType="Ellipse">

                                <Setter Property="Fill"
                                        Value="Red"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding SettingsVM.IsDeviceConnected}"
                                                 Value="True">

                                        <Setter Property="Fill"
                                                Value="Green"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </Ellipse.Style>

                    </Ellipse>


                    <TextBlock VerticalAlignment="Center"
                               Foreground="#333333">

                        <TextBlock.Style>

                            <Style TargetType="TextBlock">

                                <Setter Property="Text"
                                        Value="{Binding LocalizationProvider[EquipmentIsNotConnected]}"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding SettingsVM.IsDeviceConnected}"
                                                 Value="True">

                                        <Setter Property="Text"
                                                Value="{Binding LocalizationProvider[EquipmentIsConnected]}"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </TextBlock.Style>

                    </TextBlock>

                </StackPanel>

            </Border>

        </Grid>


        <!-- ========================= -->
        <!-- ОСНОВНАЯ ОБЛАСТЬ -->
        <!-- ========================= -->

        <Grid Grid.Column="1"
              Background="#F0F8FF">

            <ContentControl Content="{Binding CurrentViewModel}"/>

        </Grid>


    </Grid>

</Window>