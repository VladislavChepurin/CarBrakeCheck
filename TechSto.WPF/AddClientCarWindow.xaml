<Window x:Class="TechSto.WPF.AddClientCarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"           
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:helpers="clr-namespace:TechSto.WPF.Helpers"
        xmlns:сonverter="clr-namespace:TechSto.WPF.Converters"
        
        Title="{Binding LocalizationProvider[AddClientWindowTitle], Mode=OneWay}"     
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#F0F8FF">

    <Window.Resources>
        <сonverter:EnumToLocalizedStringConverter x:Key="EnumToLocalizedStringConverter"/>
        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="860">
        <StackPanel Margin="20" Width="540">

            <!-- Владелец -->
            <Border Background="White" CornerRadius="5" Margin="0,0,0,10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding LocalizationProvider[SectionOwner], Mode=OneWay}"
                               FontSize="14" FontWeight="Bold" Foreground="#0066CC" Margin="0,0,0,10"/>

                    <!-- радиокнопки -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Content="{Binding LocalizationProvider[NewOwner], Mode=OneWay}"
                                     IsChecked="{Binding IsNewOwner, Mode=TwoWay}"
                                     Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                        <RadioButton Content="{Binding LocalizationProvider[ExistingOwner], Mode=OneWay}"
                                     IsChecked="{Binding IsExistingOwner, Mode=TwoWay}"
                                     VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- поля нового владельца -->
                    <StackPanel IsEnabled="{Binding CanEditOwnerFields}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[OwnerNameLabel], Mode=OneWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding OwnerName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[OwnerSurnameLabel], Mode=OneWay}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding STSNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>
                    </StackPanel>

                    <!-- выбор существующего владельца -->
                    <ComboBox IsEnabled="{Binding IsExistingOwner}"
                              ItemsSource="{Binding Owners}"
                              SelectedItem="{Binding SelectedExistingOwner}"
                              DisplayMemberPath="Name"
                              IsEditable="True"
                              TextSearch.TextPath="Name"
                              Height="28"
                              Margin="0,5,0,0"/>

                    <!-- инфо выбранного владельца -->
                    <StackPanel Visibility="{Binding IsExistingOwner, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,0">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[OwnerNameLabel], Mode=OneWay}" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedExistingOwner.Name}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[OwnerSurnameLabel], Mode=OneWay}" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedExistingOwner.Surname}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Авто -->
            <Border Background="White" CornerRadius="5" Margin="0,0,0,10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding LocalizationProvider[SectionCar], Mode=OneWay}"
                               FontSize="14" FontWeight="Bold" Foreground="#0066CC" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LocalizationProvider[GosNumberLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding GosNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Height="26" Padding="4,3"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LocalizationProvider[VinNumberLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Vin, UpdateSourceTrigger=PropertyChanged}"
                                 Height="26" Padding="4,3"/>
                    </Grid>

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LocalizationProvider[ModelLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding CarModels}"
                                  SelectedItem="{Binding SelectedCarModel}"
                                  Height="28"
                                  Margin="0,0,8,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding CarBrand.BrandName}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding ModelName}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="2"
                                Content="{Binding LocalizationProvider[NewModelBtn], Mode=OneWay}"
                                Command="{Binding ToggleNewModelCommand}"
                                Height="28" Padding="10,0"/>
                    </Grid>

                    <!-- инфо выбранной модели -->
                    <Border Visibility="{Binding HasSelectedModel, Converter={StaticResource BoolToVis}}"
                            Background="#F0F8FF" CornerRadius="4" Padding="10,6" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Foreground="#555" FontSize="11">
                                    <Run Text="{Binding LocalizationProvider[MaxMassLabel], Mode=OneWay}"/><Run Text=": "/>
                                    <Run Text="{Binding SelectedCarModel.MaxMass}"/>
                                </TextBlock>
                                <TextBlock Foreground="#555" FontSize="11">
                                    <Run Text="{Binding LocalizationProvider[CurbMassLabel], Mode=OneWay}"/><Run Text=": "/>
                                    <Run Text="{Binding SelectedCarModel.CurbMass}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Foreground="#555" FontSize="11">
                                    <Run Text="{Binding LocalizationProvider[BrakeDiffLabel], Mode=OneWay}"/><Run Text=": "/>
                                    <Run Text="{Binding SelectedCarModel.BrakeForceDifference}"/>
                                </TextBlock>
                                <TextBlock Foreground="#555" FontSize="11">
                                    <Run Text="{Binding LocalizationProvider[CategoryLabel], Mode=OneWay}"/><Run Text=": "/>
                                    <Run Text="{Binding SelectedCarModel.CarСategory.CategoryName}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- новая модель -->
            <Expander IsExpanded="{Binding IsNewModelExpanded}"
                      Background="White"
                      Margin="0,0,0,10">
                <Expander.Style>
                    <Style TargetType="Expander">
                        <Setter Property="BorderBrush" Value="#B3D9FF"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </Expander.Style>
                <Expander.Header>
                    <TextBlock Text="{Binding LocalizationProvider[SectionNewModel], Mode=OneWay}"
                               FontSize="13" FontWeight="Bold" Foreground="#0066CC" Margin="4,0"/>
                </Expander.Header>
                <Border Padding="15,10" Background="White">
                    <StackPanel>

                        <!-- Марка -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[BrandLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Brands}"
                                      SelectedItem="{Binding SelectedBrand}"
                                      DisplayMemberPath="BrandName"
                                      Height="28"
                                      Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="{Binding LocalizationProvider[NewBrandBtn], Mode=OneWay}"
                                    Command="{Binding ToggleNewBrandCommand}"
                                    Height="28" Padding="10,0"/>
                        </Grid>

                        <!-- поле новой марки -->
                        <Grid Margin="0,0,0,8"
                              Visibility="{Binding IsNewBrandMode, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[BrandNameLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewBrandName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3" Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="{Binding LocalizationProvider[CreateBrandBtn], Mode=OneWay}"
                                    Command="{Binding CreateBrandCommand}"
                                    Height="28" Padding="10,0"/>
                        </Grid>

                        <!-- Название модели -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[ModelLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewModelName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>

                        <!-- Категория -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[CategoryLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      DisplayMemberPath="CategoryName"
                                      Height="28"/>
                        </Grid>

                        <!-- Макс масса -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[MaxMassLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding MaxMass, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>

                        <!-- Снаряж масса -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[CurbMassLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding CurbMass, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>

                        <!-- Разница тормозного усилия -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[BrakeDiffLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding BrakeForceDiff, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>

                        <!-- Стояночный тормоз -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[ParkingBrakeLabel], Mode=OneWay}" VerticalAlignment="Center"/>

                            <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ParkingBrakeChoices}"
                                  SelectedValue="{Binding SelectedParkingBrake}"
                                  SelectedValuePath="Value"
                                  DisplayMemberPath="Display"
                                  Height="28">
                            </ComboBox>
                            
                        </Grid>

                        <!-- Резервный тормоз -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[ReserveBrakeLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                 ItemsSource="{Binding ReserveBrakeChoices}"
                                 SelectedValue="{Binding SelectedReserveBrake}"
                                 SelectedValuePath="Value"
                                 DisplayMemberPath="Display"
                                 Height="28"/>
                        </Grid>

                        <!-- Количество осей -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding LocalizationProvider[AxleCountLabel], Mode=OneWay}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="−"
                                    Command="{Binding DecreaseAxleCountCommand}"
                                    Width="28" Height="28"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding AxleCount}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="14"/>
                            <Button Grid.Column="3"
                                    Content="+"
                                    Command="{Binding IncreaseAxleCountCommand}"
                                    Width="28" Height="28"/>
                        </Grid>

                        <!-- Таблица осей -->
                        <DataGrid ItemsSource="{Binding Axles}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F5F5F5"
                                  GridLinesVisibility="None"
                                  RowHeaderWidth="0"
                                  MinHeight="50"
                                  MaxHeight="200"
                                  Margin="0,0,0,12"
                                  PreviewMouseLeftButtonDown="AxlesGrid_PreviewMouseLeftButtonDown">

                            <DataGrid.Columns>
                                <!-- Колонка "№" (порядковый номер оси) -->
                                <DataGridTextColumn Header="№"
                        Binding="{Binding Order}"
                        IsReadOnly="True"
                        Width="38"/>

                                <!-- Колонка "Направление вращения" -->
                                <DataGridTemplateColumn Header="{Binding Data.LocalizationProvider[AxleDirection], Mode=OneWay, Source={StaticResource Proxy}}" Width="115">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center" Margin="4,0">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource EnumToLocalizedStringConverter}">
                                                        <Binding Path="RotationDirection" />
                                                        <Binding Path="DataContext.LocalizationProvider" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>                                 
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.RotationDirectionChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                          DisplayMemberPath="Display"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding RotationDirection, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          Height="24"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <!-- Колонка "Стояночный тормоз на оси" (флаг) -->
                                <DataGridTemplateColumn Header="{Binding Data.LocalizationProvider[AxleParkingBrake], Mode=OneWay, Source={StaticResource Proxy}}" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding HasParkingBrake, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Колонка "Тип тормоза" -->
                                <DataGridTemplateColumn Header="{Binding Data.LocalizationProvider[AxleBrakeType], Mode=OneWay, Source={StaticResource Proxy}}" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>          
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center" Margin="4,0">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource EnumToLocalizedStringConverter}">
                                                        <Binding Path="BrakeType" />
                                                        <Binding Path="DataContext.LocalizationProvider" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.BrakeTypeChoices, RelativeSource={RelativeSource AncestorType=Window}}"
                                                DisplayMemberPath="Display"
                                                SelectedValuePath="Value"
                                                SelectedValue="{Binding BrakeType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                Height="24"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <!-- Колонка "Регулятор тормозных сил" (флаг) -->
                                <DataGridTemplateColumn Header="{Binding Data.LocalizationProvider[AxleRegulator], Mode=OneWay, Source={StaticResource Proxy}}" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding HasRegulator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="{Binding LocalizationProvider[CreateModelBtn], Mode=OneWay}"
                                Command="{Binding CreateModelCommand}"
                                HorizontalAlignment="Left"
                                Height="30" Padding="18,0"/>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- список добавленных авто -->
            <ItemsControl ItemsSource="{Binding PendingCars}" Margin="0,0,0,5">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PendingCars.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}"
                                   Foreground="#0066CC"
                                   FontSize="12"
                                   Margin="0,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- кнопки панели действий -->
            <Border Background="White" CornerRadius="5" Margin="0,5,0,5" Padding="15,10">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{Binding LocalizationProvider[AddAnotherCarBtn], Mode=OneWay}"
                            Command="{Binding AddAnotherCarCommand}"
                            Visibility="{Binding IsNotEditMode, Converter={StaticResource BoolToVis}}"
                            Height="32" Padding="15,0" Margin="5"/>
                    <Button Content="{Binding LocalizationProvider[SaveAllBtn], Mode=OneWay}"
                            Command="{Binding SaveCommand}"
                            Height="32" Padding="15,0" Margin="5"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>