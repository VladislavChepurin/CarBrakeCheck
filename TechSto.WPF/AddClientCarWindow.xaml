<Window x:Class="TechSto.AddClientCarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:TechSto.WPF.Properties"
        xmlns:entity="clr-namespace:TechSto.Core.Entities"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{x:Static properties:Resources.AddClientWindowTitle}"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#F0F8FF">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="RotationDirections" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="entity:RotationDirection"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="BrakeTypes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="entity:BrakeType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="860">
        <StackPanel Margin="20" Width="540">

            <!-- Влалделец -->
            <Border Background="White" CornerRadius="5" Margin="0,0,0,10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{x:Static properties:Resources.SectionOwner}"
                               FontSize="14" FontWeight="Bold" Foreground="#0066CC" Margin="0,0,0,10"/>

                    <!-- радиокнопки -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Content="{x:Static properties:Resources.NewOwner}"
                                     IsChecked="{Binding IsNewOwner, Mode=TwoWay}"
                                     Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                        <RadioButton Content="{x:Static properties:Resources.ExistingOwner}"
                                     IsChecked="{Binding IsExistingOwner, Mode=TwoWay}"
                                     VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- поля нового владельца -->
                    <StackPanel IsEnabled="{Binding CanEditOwnerFields}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.OwnerNameLabel}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding OwnerName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.StsNumberLabel}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding STSNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>
                    </StackPanel>

                    <!-- выбор сущ -->
                    <ComboBox IsEnabled="{Binding IsExistingOwner}"
                              ItemsSource="{Binding Owners}"
                              SelectedItem="{Binding SelectedExistingOwner}"
                              DisplayMemberPath="Name"
                              IsEditable="True"
                              TextSearch.TextPath="Name"
                              Height="28"
                              Margin="0,5,0,0"/>

                    <!-- инфо выбранного владельца -->
                    <StackPanel Visibility="{Binding IsExistingOwner, Converter={StaticResource BoolToVis}}"
                                Margin="0,8,0,0">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.OwnerNameLabel}" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedExistingOwner.Name}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.StsNumberLabel}" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedExistingOwner.STSNumber}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Авто -->
            <Border Background="White" CornerRadius="5" Margin="0,0,0,10" Padding="15">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{x:Static properties:Resources.SectionCar}"
                               FontSize="14" FontWeight="Bold" Foreground="#0066CC" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static properties:Resources.GosNumberLabel}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding GosNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Height="26" Padding="4,3"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static properties:Resources.VinNumberLabel}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Vin, UpdateSourceTrigger=PropertyChanged}"
                                 Height="26" Padding="4,3"/>
                    </Grid>

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static properties:Resources.ModelLabel}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding CarModels}"
                                  SelectedItem="{Binding SelectedCarModel}"
                                  Height="28"
                                  Margin="0,0,8,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding CarBrand.BrandName}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding ModelName}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="2"
                                Content="{x:Static properties:Resources.NewModelBtn}"
                                Command="{Binding ToggleNewModelCommand}"
                                Height="28" Padding="10,0"/>
                    </Grid>

                    <!-- инфо выбранной модели -->
                    <Border Visibility="{Binding HasSelectedModel, Converter={StaticResource BoolToVis}}"
                            Background="#F0F8FF" CornerRadius="4" Padding="10,6" Margin="0,4,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Foreground="#555" FontSize="11">
                                    <Run Text="{x:Static properties:Resources.MaxMassLabel}"/><Run Text=": "/>
                                    <Run Text="{Binding SelectedCarModel.MaxMass}"/>
                                </TextBlock>
                                <TextBlock Foreground="#555" FontSize="11">
                                    <Run Text="{x:Static properties:Resources.CurbMassLabel}"/><Run Text=": "/>
                                    <Run Text="{Binding SelectedCarModel.CurbMass}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Foreground="#555" FontSize="11">
                                    <Run Text="{x:Static properties:Resources.BrakeDiffLabel}"/><Run Text=": "/>
                                    <Run Text="{Binding SelectedCarModel.BrakeForceDifference}"/>
                                </TextBlock>
                                <TextBlock Foreground="#555" FontSize="11">
                                    <Run Text="{x:Static properties:Resources.CategoryLabel}"/><Run Text=": "/>
                                    <Run Text="{Binding SelectedCarModel.CarСategory.CategoryName}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- нов модель -->
            <Expander IsExpanded="{Binding IsNewModelExpanded}"
                      Background="White"
                      Margin="0,0,0,10">
                <Expander.Style>
                    <Style TargetType="Expander">
                        <Setter Property="BorderBrush" Value="#B3D9FF"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </Expander.Style>
                <Expander.Header>
                    <TextBlock Text="{x:Static properties:Resources.SectionNewModel}"
                               FontSize="13" FontWeight="Bold" Foreground="#0066CC" Margin="4,0"/>
                </Expander.Header>
                <Border Padding="15,10" Background="White">
                    <StackPanel>

                        <!-- Марка -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.BrandLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Brands}"
                                      SelectedItem="{Binding SelectedBrand}"
                                      DisplayMemberPath="BrandName"
                                      Height="28"
                                      Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="{x:Static properties:Resources.NewBrandBtn}"
                                    Command="{Binding ToggleNewBrandCommand}"
                                    Height="28" Padding="10,0"/>
                        </Grid>

                        <!-- поле новой марки -->
                        <Grid Margin="0,0,0,8"
                              Visibility="{Binding IsNewBrandMode, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.BrandNameLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewBrandName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3" Margin="0,0,8,0"/>
                            <Button Grid.Column="2"
                                    Content="{x:Static properties:Resources.CreateBrandBtn}"
                                    Command="{Binding CreateBrandCommand}"
                                    Height="28" Padding="10,0"/>
                        </Grid>

                        <!-- Название модели -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.ModelLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding NewModelName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>

                        <!-- Категория -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.CategoryLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      DisplayMemberPath="CategoryName"
                                      Height="28"/>
                        </Grid>

                        <!-- Макс масса -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.MaxMassLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding MaxMass, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>

                        <!-- Снаряж масса -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.CurbMassLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding CurbMass, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>

                        <!-- Разница тормозного усилия -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.BrakeDiffLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding BrakeForceDiff, UpdateSourceTrigger=PropertyChanged}"
                                     Height="26" Padding="4,3"/>
                        </Grid>

                        <!-- Стояночный тормоз -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.ParkingBrakeLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ParkingBrakeChoices}"
                                      SelectedItem="{Binding SelectedParkingBrake}"
                                      Height="28">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="—"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <!-- Резервный тормоз -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.ReserveBrakeLabel}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ReserveBrakeChoices}"
                                      SelectedItem="{Binding SelectedReserveBrake}"
                                      Height="28">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="—"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <!-- Количество осей -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Static properties:Resources.AxleCountLabel}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="−"
                                    Command="{Binding DecreaseAxleCountCommand}"
                                    Width="28" Height="28"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding AxleCount}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="14"/>
                            <Button Grid.Column="3"
                                    Content="+"
                                    Command="{Binding IncreaseAxleCountCommand}"
                                    Width="28" Height="28"/>
                        </Grid>

                        <!-- Таблица осей -->
                        <DataGrid ItemsSource="{Binding Axles}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F5F5F5"
                                  GridLinesVisibility="None"
                                  RowHeaderWidth="0"
                                  MinHeight="50"
                                  MaxHeight="200"
                                  Margin="0,0,0,12"
                                  PreviewMouseLeftButtonDown="AxlesGrid_PreviewMouseLeftButtonDown">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№"
                                                    Binding="{Binding Order}"
                                                    IsReadOnly="True"
                                                    Width="38"/>

                                <DataGridTemplateColumn Header="{x:Static properties:Resources.AxleDirection}" Width="115">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RotationDirection}"
                                                       VerticalAlignment="Center" Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedItem="{Binding RotationDirection, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                      ItemsSource="{Binding Source={StaticResource RotationDirections}}"
                                                      Height="24"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static properties:Resources.AxleParkingBrake}" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding HasParkingBrake, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static properties:Resources.AxleBrakeType}" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BrakeType}"
                                                       VerticalAlignment="Center" Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedItem="{Binding BrakeType, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                      ItemsSource="{Binding Source={StaticResource BrakeTypes}}"
                                                      Height="24"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="{x:Static properties:Resources.AxleRegulator}" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding HasRegulator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="{x:Static properties:Resources.CreateModelBtn}"
                                Command="{Binding CreateModelCommand}"
                                HorizontalAlignment="Left"
                                Height="30" Padding="18,0"/>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- список добавленных авто -->
            <ItemsControl ItemsSource="{Binding PendingCars}" Margin="0,0,0,5">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PendingCars.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}"
                                   Foreground="#0066CC"
                                   FontSize="12"
                                   Margin="0,2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- кнопки панели действий -->
            <Border Background="White" CornerRadius="5" Margin="0,5,0,5" Padding="15,10">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="5"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{x:Static properties:Resources.AddAnotherCarBtn}"
                            Command="{Binding AddAnotherCarCommand}"
                            Visibility="{Binding IsNotEditMode, Converter={StaticResource BoolToVis}}"
                            Height="32" Padding="15,0" Margin="5"/>
                    <Button Content="{x:Static properties:Resources.SaveAllBtn}"
                            Command="{Binding SaveCommand}"
                            Height="32" Padding="15,0" Margin="5"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
